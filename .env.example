# === Cerebro del agente ===
# "ollama" (local/gratis) | "anthropic" | "openai"
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=hermes3:8b
# Solo si LLM_PROVIDER != ollama:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === Servidor ===
PORT=8000
# OBLIGATORIO antes de la demo: si AUTHORIZED_WHATSAPP_ID queda vacío, el agente ignora a
# TODOS (falla cerrado). Arranca el orchestrator, manda un mensaje de prueba y copia el "from"
# que aparece en el log `{event=webhook, from=...}`.
AUTHORIZED_WHATSAPP_ID=

# === Memoria ===
MEMORY_DIR=./memory
MAX_SHORT_TERM=20

# === Límites duros (harness) ===
MAX_TOOL_ROUNDS=5
TOOL_TIMEOUT_S=10
MAX_REPLY_CHARS=1500
WEB_TRUNCATE_CHARS=4000

# === Tools (dejar vacío lo que no se use) ===
GMAIL_USER=
GMAIL_APP_PASSWORD=
GOOGLE_SHEET_ID=
GOOGLE_CREDENTIALS_PATH=./config/credentials.json
